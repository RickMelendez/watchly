# Backend Environment Variables for Railway
# Add these in: Railway Dashboard → Backend Service → Variables tab

# Required: Railway PostgreSQL plugin provides this automatically
# Click "Add Plugin" → PostgreSQL and it will be set
DATABASE_URL=postgresql://user:password@host:port/dbname

# Required: Use a strong random string (never commit the real value)
JWT_SECRET_KEY=change-me-to-a-strong-random-secret

# Required: Your Cloudflare Pages URL (no trailing slash)
# Set to your full domain after deploying the frontend
# Multiple URLs comma-separated: https://watchly.pages.dev,https://watchly.com
FRONTEND_URL=https://your-project.pages.dev

# Optional: Only needed for email alert notifications
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Set to 0 in production
FLASK_DEBUG=0

# Optional: logging level for backend service (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: enable only for local bootstrap, keep 0 in production
AUTO_CREATE_SCHEMA=0
